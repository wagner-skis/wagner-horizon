{%- comment -%}
  Graphics explorer overlay for Skier DNA.
  Lives OUTSIDE #skier-dna-root so island innerHTML replacements never destroy it.
  Source priority:
    1. graphic_category blocks — each block is one named collection tab.
    2. graphics_collection setting — single collection, tabs from product.type.
  Hidden until skier-dna.js sets overlay.hidden = false.
  Parameters: section
{%- endcomment -%}

{%- assign sd_gv_block_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'graphic_category' and block.settings.collection != blank -%}
    {%- assign sd_gv_block_count = sd_gv_block_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if sd_gv_block_count > 0 or section.settings.graphics_collection != blank -%}

  <div id="sd-graphics-overlay" class="sd-gv-overlay" hidden aria-modal="true" role="dialog" aria-label="Explore graphics">

    <graphic-viewer
      class="graphic-viewer sd-gv-viewer"
      data-section-id="{{ section.id }}-gv"
      data-grid-panel-id="sd-gv-grid-{{ section.id }}"
    >

      <div class="graphic-viewer__toolbar">
        <button type="button" class="sd-gv-close" aria-label="Close graphics explorer" data-sd-gv-close>
          <svg viewBox="0 0 18 18" aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <line x1="3" y1="3" x2="15" y2="15"/><line x1="15" y1="3" x2="3" y2="15"/>
          </svg>
        </button>
        <button type="button" ref="modeBtns[]" class="graphic-viewer__mode-btn" data-mode="viewer"
          aria-pressed="true" aria-label="Viewer mode" on:click="graphic-viewer/handleModeToggle">
          <svg viewBox="0 0 18 18" aria-hidden="true"><rect x="1" y="1" width="7" height="16" rx="1"/><rect x="10" y="1" width="7" height="16" rx="1"/></svg>
        </button>
        <button type="button" ref="modeBtns[]" class="graphic-viewer__mode-btn" data-mode="grid"
          aria-pressed="false" aria-label="Grid mode" on:click="graphic-viewer/handleModeToggle">
          <svg viewBox="0 0 18 18" aria-hidden="true"><rect x="1" y="1" width="7" height="7" rx="1"/><rect x="10" y="1" width="7" height="7" rx="1"/><rect x="1" y="10" width="7" height="7" rx="1"/><rect x="10" y="10" width="7" height="7" rx="1"/></svg>
        </button>
      </div>

      <div class="graphic-viewer__viewer-panel" ref="viewerPanel">
        <aside class="graphic-viewer__sidebar">

          {%- if sd_gv_block_count > 0 -%}
            {%- comment -%}Multi-collection mode: one graphic_category block = one filter tab.{%- endcomment -%}
            <div class="graphic-viewer__filter-row" role="group" aria-label="Category filter">
              <button type="button" ref="tierBtns[]" class="graphic-viewer__tier-btn"
                data-tier="all" aria-pressed="true" on:click="graphic-viewer/handleTierFilter">All</button>
              {%- for block in section.blocks -%}
                {%- if block.type == 'graphic_category' and block.settings.collection != blank -%}
                  {%- assign sd_gv_col = collections[block.settings.collection] -%}
                  {%- if sd_gv_col != blank -%}
                    <button type="button" ref="tierBtns[]" class="graphic-viewer__tier-btn"
                      data-tier="{{ block.settings.collection | handleize }}"
                      aria-pressed="false"
                      on:click="graphic-viewer/handleTierFilter">
                      {{- block.settings.name | default: sd_gv_col.title -}}
                    </button>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>

            <div class="graphic-viewer__thumb-list" role="list" aria-label="Graphics">
              {%- assign sd_gv_thumb_idx = 0 -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'graphic_category' and block.settings.collection != blank -%}
                  {%- assign sd_gv_col = collections[block.settings.collection] -%}
                  {%- if sd_gv_col != blank -%}
                    {%- for product in sd_gv_col.products -%}
                      <div ref="thumbs[]" class="graphic-viewer__thumb" role="button" tabindex="0"
                        data-handle="{{ product.handle }}"
                        data-tier="{{ block.settings.collection | handleize }}"
                        data-image="{{ product.featured_image | image_url: width: 1200 }}"
                        data-title="{{ product.title | escape }}"
                        data-collection="{{ block.settings.name | default: sd_gv_col.title | escape }}"
                        data-price="{{ product.price }}"
                        data-url="{{ product.url }}"
                        aria-label="{{ product.title | escape }}"
                        aria-pressed="{% if sd_gv_thumb_idx == 0 %}true{% else %}false{% endif %}"
                        on:click="graphic-viewer/handleThumbClick"
                        on:keydown="graphic-viewer/handleThumbKeydown"
                      >
                        {%- if product.featured_image -%}
                          <img src="{{ product.featured_image | image_url: width: 400 }}"
                            alt="{{ product.title | escape }}" loading="lazy" width="200" height="200"
                            class="graphic-viewer__thumb-img">
                        {%- endif -%}
                        {%- assign sd_gv_thumb_idx = sd_gv_thumb_idx | plus: 1 -%}
                      </div>
                    {%- endfor -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>

          {%- else -%}
            {%- comment -%}Single-collection fallback: tabs from product.type.{%- endcomment -%}
            {%- assign sd_gv_col = collections[section.settings.graphics_collection] -%}
            {%- liquid
              assign gv_type_list = ''
              for product in sd_gv_col.products
                assign type_key = product.type | handleize
                if type_key != blank
                  assign type_seen = false
                  assign gv_types_so_far = gv_type_list | split: '|||'
                  for seen_entry in gv_types_so_far
                    assign seen_parts = seen_entry | split: '::'
                    if seen_parts[0] == type_key
                      assign type_seen = true
                    endif
                  endfor
                  unless type_seen
                    unless gv_type_list == ''
                      assign gv_type_list = gv_type_list | append: '|||'
                    endunless
                    assign gv_type_list = gv_type_list | append: type_key | append: '::' | append: product.type
                  endunless
                endif
              endfor
              assign gv_unique_types = gv_type_list | split: '|||'
            -%}
            {%- if gv_unique_types.size > 0 -%}
              <div class="graphic-viewer__filter-row" role="group" aria-label="Category filter">
                <button type="button" ref="tierBtns[]" class="graphic-viewer__tier-btn"
                  data-tier="all" aria-pressed="true" on:click="graphic-viewer/handleTierFilter">All</button>
                {%- for type_entry in gv_unique_types -%}
                  {%- assign type_parts = type_entry | split: '::' -%}
                  <button type="button" ref="tierBtns[]" class="graphic-viewer__tier-btn"
                    data-tier="{{ type_parts[0] }}" aria-pressed="false"
                    on:click="graphic-viewer/handleTierFilter">{{ type_parts[1] }}</button>
                {%- endfor -%}
              </div>
            {%- endif -%}
            <div class="graphic-viewer__thumb-list" role="list" aria-label="Graphics">
              {%- for product in sd_gv_col.products -%}
                <div ref="thumbs[]" class="graphic-viewer__thumb" role="button" tabindex="0"
                  data-handle="{{ product.handle }}"
                  data-tier="{{ product.type | handleize }}"
                  data-image="{{ product.featured_image | image_url: width: 1200 }}"
                  data-title="{{ product.title | escape }}"
                  data-collection="{{ product.type | escape }}"
                  data-price="{{ product.price }}"
                  data-url="{{ product.url }}"
                  aria-label="{{ product.title | escape }}"
                  aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
                  on:click="graphic-viewer/handleThumbClick"
                  on:keydown="graphic-viewer/handleThumbKeydown"
                >
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | image_url: width: 400 }}"
                      alt="{{ product.title | escape }}" loading="lazy" width="200" height="200"
                      class="graphic-viewer__thumb-img">
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

        </aside>

        <div class="graphic-viewer__stage-area">
          <div class="graphic-viewer__metadata" aria-live="polite" aria-atomic="true">
            <span class="graphic-viewer__metadata-series" ref="metaSeries"></span>
            <span class="graphic-viewer__metadata-name" ref="metaName"></span>
          </div>
          <div class="graphic-viewer__stage" ref="stage" aria-hidden="true">
            <div class="graphic-viewer__stage-layer" ref="stageLayers[]" data-layer="a"></div>
            <div class="graphic-viewer__stage-layer" ref="stageLayers[]" data-layer="b"></div>
          </div>
          <div class="graphic-viewer__info-strip">
            <div class="graphic-viewer__msrp">
              <span class="graphic-viewer__msrp-label">MSRP Starting At</span>
              <span class="graphic-viewer__msrp-value" ref="msrpValue"></span>
            </div>
            <div class="graphic-viewer__actions">
              <a ref="ctaPrimary" class="graphic-viewer__cta graphic-viewer__cta--primary" href="#">Customize This Pair</a>
              <a ref="ctaSecondary" class="graphic-viewer__cta graphic-viewer__cta--secondary" href="#">Technical Specs</a>
            </div>
          </div>
        </div>
      </div>

    </graphic-viewer>

    <div id="sd-gv-grid-{{ section.id }}" hidden></div>

  </div>

  {{ 'graphic-viewer.css' | asset_url | stylesheet_tag }}
  <script type="module">import '@theme/graphic-viewer';</script>

{%- endif -%}
