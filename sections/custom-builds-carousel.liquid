{%- liquid
  assign metaobject_type = section.settings.metaobject_type | default: 'custom_builds'
  assign all_builds      = shop.metaobjects[metaobject_type].values
  assign columns         = section.settings.columns
  assign columns_gap     = section.settings.columns_gap
  assign mobile_size     = section.settings.mobile_card_size

  # Count total builds and discover unique graphic categories present in the feed
  assign build_count_all = 0
  assign category_list   = ''

  for build in all_builds
    assign build_count_all = build_count_all | plus: 1
    assign cat = build.graphic_category.value
    if cat != blank
      assign check_cats = category_list | split: '|||'
      assign cat_found  = false
      for c in check_cats
        if c == cat
          assign cat_found = true
        endif
      endfor
      unless cat_found
        if category_list != ''
          assign category_list = category_list | append: '|||'
        endif
        assign category_list = category_list | append: cat
      endunless
    endif
  endfor

  assign unique_categories = category_list | split: '|||'
-%}

{%- capture all_list_items -%}
  {%- assign is_first = true -%}
  {%- for build in all_builds -%}
    {%- unless is_first -%}<!--@list/split-->{%- endunless -%}
    <div class="resource-list__item">{%- render 'custom-build-card', build: build -%}</div>
    {%- assign is_first = false -%}
  {%- endfor -%}
{%- endcapture -%}
{%- assign all_items_array = all_list_items | split: '<!--@list/split-->' -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-custom-builds-carousel
    spacing-style
  "
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    --card-title-size: {{ section.settings.title_size }}px;
    --card-title-weight: {{ section.settings.title_weight }};
    --card-title-transform: {{ section.settings.title_transform }};
    --card-dims-size: {{ section.settings.dimensions_size }}px;
    --card-material-size: {{ section.settings.material_size }}px;
    --card-price-size: {{ section.settings.price_size }}px;
    --card-price-weight: {{ section.settings.price_weight }};
  "
>
  {%- if section.settings.heading != blank -%}
    <div class="custom-builds-carousel__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="wagner-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {{ section.settings.heading }}
    </div>
  {%- endif -%}

  <div
    class="custom-builds-carousel
      {%- unless section.settings.show_title %} hide-card-title{%- endunless -%}
      {%- unless section.settings.show_dimensions %} hide-card-dims{%- endunless -%}
      {%- unless section.settings.show_material %} hide-card-material{%- endunless -%}
      {%- unless section.settings.show_price %} hide-card-price{%- endunless -%}
    "
    id="custom-builds-{{ section.id }}"
  >
    <div class="custom-builds-carousel__filter-bar" role="group" aria-label="Filter builds by graphic type">
      <button
        class="custom-builds-carousel__filter-btn"
        data-filter="all"
        aria-pressed="true"
      >
        {{- section.settings.filter_all_label | default: 'All Builds' -}}
      </button>
      {%- for category in unique_categories -%}
        {%- if category != blank -%}
          <button
            class="custom-builds-carousel__filter-btn"
            data-filter="{{ category | handleize }}"
            aria-pressed="false"
          >
            {{- category -}}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} All builds panel — visible by default {%- endcomment -%}
    <div class="custom-builds-carousel__panel" data-panel="all">
      <div
        class="resource-list resource-list__carousel force-full-width"
        style="
          --resource-list-column-gap-desktop: {{ columns_gap }}px;
          --column-count: {{ columns }};
          --column-count-mobile: 1;
          --mobile-card-size: {{ mobile_size }};
        "
      >
        {%- render 'resource-list-carousel',
          ref: 'customBuildsAll',
          slides: all_items_array,
          slide_count: build_count_all,
          settings: section.settings,
          slide_width_max: '480px'
        -%}
      </div>
    </div>

    {%- comment -%} Per-category panels — built dynamically from feed {%- endcomment -%}
    {%- for category in unique_categories -%}
      {%- if category != blank -%}
        {%- assign cat_slug = category | handleize -%}
        {%- assign cat_ref  = 'customBuilds-' | append: section.id | append: '-' | append: cat_slug -%}

        {%- capture cat_list_items -%}
          {%- assign cat_is_first = true -%}
          {%- for build in all_builds -%}
            {%- if build.graphic_category.value == category -%}
              {%- unless cat_is_first -%}<!--@list/split-->{%- endunless -%}
              <div class="resource-list__item">{%- render 'custom-build-card', build: build -%}</div>
              {%- assign cat_is_first = false -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endcapture -%}
        {%- assign cat_items_array = cat_list_items | split: '<!--@list/split-->' -%}

        <div class="custom-builds-carousel__panel" data-panel="{{ cat_slug }}" hidden>
          <div
            class="resource-list resource-list__carousel force-full-width"
            style="
              --resource-list-column-gap-desktop: {{ columns_gap }}px;
              --column-count: {{ columns }};
              --column-count-mobile: 1;
              --mobile-card-size: {{ mobile_size }};
            "
          >
            {%- render 'resource-list-carousel',
              ref: cat_ref,
              slides: cat_items_array,
              slide_count: cat_items_array.size,
              settings: section.settings,
              slide_width_max: '480px'
            -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script type="module">
  const section = document.getElementById('custom-builds-{{ section.id }}');
  if (section) {
    const buttons = section.querySelectorAll('.custom-builds-carousel__filter-btn');
    const panels  = section.querySelectorAll('[data-panel]');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        buttons.forEach(b => b.setAttribute('aria-pressed', String(b === btn)));
        panels.forEach(p => { p.hidden = p.dataset.panel !== filter; });
      });
    });
  }
</script>

{% stylesheet %}
  .section-custom-builds-carousel {
    container-type: inline-size;
  }

  .custom-builds-carousel__header {
    padding-block-end: var(--padding-md, 20px);
  }

  .custom-builds-carousel__filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-2xs, 6px);
    padding-block-end: var(--padding-sm, 16px);
  }

  .custom-builds-carousel__filter-btn {
    font-family: var(--font-subheading--family, var(--font-body--family));
    font-size: 0.6875rem;
    letter-spacing: var(--wagner-eyebrow-tracking, 0.18em);
    text-transform: uppercase;
    padding: 7px 16px;
    border: 1px solid rgb(var(--color-border) / 0.5);
    background-color: transparent;
    color: rgb(var(--color-foreground) / 0.55);
    cursor: pointer;
    border-radius: var(--style-border-radius-buttons, 0);
    transition:
      border-color var(--animation-speed, 200ms) ease,
      color var(--animation-speed, 200ms) ease,
      background-color var(--animation-speed, 200ms) ease;
  }

  .custom-builds-carousel__filter-btn[aria-pressed="true"] {
    border-color: rgb(var(--color-foreground));
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-foreground) / 0.06);
  }

  .custom-builds-carousel__filter-btn:hover:not([aria-pressed="true"]) {
    border-color: rgb(var(--color-foreground) / 0.7);
    color: rgb(var(--color-foreground) / 0.8);
  }

  @media (prefers-reduced-motion: reduce) {
    .custom-builds-carousel__filter-btn { transition: none; }
  }

  /* Card layout */
  .custom-build-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .custom-build-card__media {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .custom-build-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--animation-speed-medium, 400ms) cubic-bezier(0.4, 0, 0.2, 1);
  }

  .custom-build-card:hover .custom-build-card__media img {
    transform: scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .custom-build-card__media img { transition: none; }
  }

  .custom-build-card__info {
    padding-block-start: var(--padding-xs, 12px);
    display: flex;
    flex-direction: column;
    gap: var(--gap-2xs, 4px);
    flex: 1;
  }

  .custom-build-card__title {
    font-size: var(--card-title-size, 1rem);
    font-weight: var(--card-title-weight, 400);
    text-transform: var(--card-title-transform, none);
    line-height: 1.3;
    margin: 0;
  }

  .custom-build-card__dimensions {
    font-size: var(--card-dims-size, 0.8125rem);
    color: rgb(var(--color-foreground) / 0.6);
    margin: 0;
  }

  .custom-build-card__material {
    font-size: var(--card-material-size, 0.8125rem);
    color: rgb(var(--color-foreground) / 0.6);
    margin: 0;
  }

  .custom-build-card__price {
    font-size: var(--card-price-size, 0.875rem);
    font-weight: var(--card-price-weight, 700);
    color: rgb(var(--color-foreground));
    margin: 0;
    margin-block-start: var(--margin-2xs, 4px);
  }

  /* Field visibility toggles */
  .hide-card-title .custom-build-card__title         { display: none; }
  .hide-card-dims .custom-build-card__dimensions     { display: none; }
  .hide-card-material .custom-build-card__material   { display: none; }
  .hide-card-price .custom-build-card__price         { display: none; }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Builds Carousel",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "class": "custom-builds-carousel-section",
  "settings": [
    {
      "type": "header",
      "content": "Data source"
    },
    {
      "type": "text",
      "id": "metaobject_type",
      "label": "Metaobject type handle",
      "default": "custom_builds",
      "info": "API handle found at Settings → Custom data → Metaobjects"
    },
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "inline_richtext",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Custom Builds"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<h2>Factory Skis We've Built</h2>"
    },
    {
      "type": "header",
      "content": "Filter bar"
    },
    {
      "type": "text",
      "id": "filter_all_label",
      "label": "\"All\" tab label",
      "default": "All Builds"
    },
    {
      "type": "header",
      "content": "Card: Title"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Font size",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Text case",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Card: Dimensions"
    },
    {
      "type": "checkbox",
      "id": "show_dimensions",
      "label": "Show dimensions",
      "default": true
    },
    {
      "type": "range",
      "id": "dimensions_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "header",
      "content": "Card: Core material"
    },
    {
      "type": "checkbox",
      "id": "show_material",
      "label": "Show core material",
      "default": true
    },
    {
      "type": "range",
      "id": "material_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "header",
      "content": "Card: Price"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "price_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "mobile_card_size",
      "label": "Mobile card size",
      "options": [
        { "value": "60cqw", "label": "1 card" },
        { "value": "44cqw", "label": "2 cards" }
      ],
      "default": "60cqw"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "Gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "Arrow style",
      "options": [
        { "value": "arrow", "label": "Arrow" },
        { "value": "chevron", "label": "Chevron" },
        { "value": "arrows_large", "label": "Arrow large" },
        { "value": "chevron_large", "label": "Chevron large" },
        { "value": "none", "label": "None" }
      ],
      "default": "arrow"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "Arrow background",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" }
      ],
      "default": "circle",
      "visible_if": "{{ section.settings.icons_style != 'none' }}"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Custom Builds Carousel",
      "category": "Wagner",
      "settings": {
        "metaobject_type": "custom_builds",
        "columns": 3,
        "columns_gap": 16,
        "icons_style": "arrow",
        "icons_shape": "circle",
        "padding-block-start": 48,
        "padding-block-end": 48
      }
    }
  ]
}
{% endschema %}
