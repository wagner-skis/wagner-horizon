{%- comment -%}
  content_for 'blocks' must run before any section.blocks access
  so Shopify populates the block array before our rendering loop.
  The block files are schema-only and output nothing, so this div
  is invisible on the live site and harmless in the editor.
{%- endcomment -%}
<div hidden aria-hidden="true">{% content_for 'blocks' %}</div>

{%- liquid
  assign selected_testimonials = section.settings.testimonials
  assign columns     = section.settings.columns
  assign columns_gap = section.settings.columns_gap
  assign mobile_size = section.settings.mobile_card_size
-%}

{%- if selected_testimonials != blank and section.blocks.size > 0 -%}
  {%- capture slides_html -%}
    {%- assign is_first = true -%}
    {%- for t in selected_testimonials -%}
      {%- unless is_first -%}<!--@list/split-->{%- endunless -%}
      {%- assign t_url = t.url -%}
      <div class="resource-list__item">
        <article class="testimonial-card">
          {%- for block in section.blocks -%}
            {%- render 'testimonial-field-block', block: block, t: t, t_url: t_url -%}
          {%- endfor -%}
        </article>
      </div>
      {%- assign is_first = false -%}
    {%- endfor -%}
  {%- endcapture -%}
  {%- assign slides_array = slides_html | split: '<!--@list/split-->' -%}
{%- endif -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-testimonials-carousel
    spacing-style
  "
  style="{%- render 'spacing-style', settings: section.settings -%}"
>
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="testimonials-carousel__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="wagner-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {{ section.settings.heading }}
    </div>
  {%- endif -%}

  {%- if slides_array != blank -%}
    <div
      class="resource-list resource-list__carousel force-full-width"
      style="
        --resource-list-column-gap-desktop: {{ columns_gap }}px;
        --column-count: {{ columns }};
        --column-count-mobile: 1;
        --mobile-card-size: {{ mobile_size }};
      "
    >
      {%- render 'resource-list-carousel',
        ref: 'testimonialsCarousel',
        slides: slides_array,
        slide_count: slides_array.size,
        settings: section.settings,
        slide_width_max: '520px'
      -%}
    </div>
  {%- elsif request.design_mode -%}
    <p class="testimonials-carousel__empty">
      {%- if selected_testimonials == blank -%}
        Select testimonial entries in the section settings to display this carousel.
      {%- else -%}
        Add field blocks in the section sidebar to build the card layout.
      {%- endif -%}
    </p>
  {%- endif -%}


</div>

{% stylesheet %}
  .section-testimonials-carousel {
    container-type: inline-size;
  }

  .testimonials-carousel__header {
    padding-block-end: var(--padding-md, 20px);
  }

  .testimonials-carousel__empty {
    font-size: 0.875rem;
    color: rgb(var(--color-foreground) / 0.5);
    font-style: italic;
    padding: var(--padding-md, 20px) 0;
  }

  /* Card */
  .testimonial-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Product image */
  .testimonial-card__product-image {
    overflow: hidden;
    aspect-ratio: var(--testimonial-aspect, 3 / 2);
    margin-block-end: var(--padding-sm, 16px);
  }

  .testimonial-card__product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--animation-speed-medium, 400ms) cubic-bezier(0.4, 0, 0.2, 1);
  }

  .testimonial-card__img-link {
    display: block;
    height: 100%;
  }

  .testimonial-card:hover .testimonial-card__product-image img {
    transform: scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-card__product-image img { transition: none; }
  }

  /* Pull quote */
  .testimonial-card__quote {
    margin: 0;
    padding: 0;
    line-height: 1.5;
    color: rgb(var(--color-foreground));
  }

  .testimonial-card__quote--italic { font-style: italic; }

  /* Attribution */
  .testimonial-card__attribution {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding-block-start: var(--padding-xs, 8px);
    border-block-start: 1px solid rgb(var(--color-border) / 0.3);
    margin-block-start: var(--margin-2xs, 8px);
  }

  .testimonial-card__client-name {
    display: block;
    font-family: var(--font-subheading--family, var(--font-body--family));
    font-size: 0.6875rem;
    letter-spacing: var(--wagner-eyebrow-tracking, 0.18em);
    text-transform: uppercase;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    text-decoration: none;
  }

  .testimonial-card__role {
    font-size: 0.8125rem;
    color: rgb(var(--color-foreground) / 0.6);
  }

  /* Bio image */
  .testimonial-card__bio-image-wrap {
    display: inline-flex;
    width: var(--bio-img-size, 48px);
    height: var(--bio-img-size, 48px);
    overflow: hidden;
    margin-block-start: var(--margin-2xs, 8px);
  }

  .testimonial-card__bio-image-wrap--circle { border-radius: 50%; }
  .testimonial-card__bio-image-wrap--square { border-radius: var(--style-border-radius-inputs, 0); }

  .testimonial-card__bio-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Description */
  .testimonial-card__description {
    color: rgb(var(--color-foreground) / 0.7);
    line-height: 1.5;
    margin-block-start: var(--margin-2xs, 8px);
  }

  .testimonial-card__description p { margin: 0; }

  /* Byline: bio image + attribution side by side */
  .testimonial-card__byline {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--gap-xs, 12px);
    margin-block-start: var(--margin-2xs, 8px);
    padding-block-start: var(--padding-xs, 8px);
    border-block-start: 1px solid rgb(var(--color-border) / 0.3);
  }

  .testimonial-card__byline > .testimonial-card__bio-image-wrap {
    flex-shrink: 0;
    margin-block-start: 0;
  }

  .testimonial-card__byline-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
{% endstylesheet %}

