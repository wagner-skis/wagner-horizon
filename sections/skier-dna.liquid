{%- comment -%}
  ============================================================================
  Skier DNA — Online Store 2.0 section scaffold
  ============================================================================
  This is a THEME SECTION version of the Skier DNA mount point. It is the
  fastest way to prototype the schema (settings + blocks) in a dev theme.

  PROMOTION TO A THEME APP EXTENSION APP BLOCK (do this once the app backend
  exists — it is what the experience actually ships as, because it needs
  server-side persistence + Klaviyo + Calendly + pre-generated copy):
    1. Move this file to  extensions/skier-dna/blocks/skier-dna.liquid
    2. Keep the {% schema %} settings + blocks EXACTLY as-is — they transfer 1:1.
    3. Replace `section.settings`/`section.blocks` with `block.settings`/
       `block.blocks`, and the `{% schema %}` "name"/"presets" with app-block
       equivalents (target: "section").
    4. Serve assets/skier-dna.js from the extension's assets/ folder.
  The five acts themselves are NEVER Liquid blocks — they are client app state
  inside #skier-dna-root. The blocks below are only the merchant-editable
  CONTENT COLLECTIONS, so Roland can re-image/re-order cards in the editor.
  ============================================================================
{%- endcomment -%}

<div
  id="skier-dna-root"
  class="color-{{ section.settings.color_scheme }}"
  data-skier-dna
  data-calendly-url="{{ section.settings.calendly_url | escape }}"
  data-klaviyo-list="{{ section.settings.klaviyo_list_id | escape }}"
  data-personalities-url="{{ section.settings.personalities_api_url | escape }}"
  data-show-packages="{{ section.settings.show_package_tiers }}"
  data-true-scale="{{ section.settings.true_scale_anchor }}"
  {%- if section.settings.graphics_collection != blank %}
  data-graphics-collection="{{ section.settings.graphics_collection }}"
  {%- endif %}
  style="
    --sd-radius: {{ section.settings.corner_radius }}px;
    --sd-font-head: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    --sd-font-body: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
    --sd-header-offset: {{ section.settings.header_offset }}px;
    min-height: calc(100svh - var(--sd-header-offset, 72px));
  "
>

  {%- comment -%} Roland-editable copy + content, handed to the island as JSON {%- endcomment -%}
  <script type="application/json" data-skier-dna-config>
    {
      "copy": {
        "heading": {{ section.settings.heading | json }},
        "subhead": {{ section.settings.subhead | json }},
        "namePrompt": {{ section.settings.name_prompt | json }},
        "emailSaveCopy": {{ section.settings.email_save_copy | json }},
        "microCtaLabel": {{ section.settings.micro_cta_label | json }},
        "gateCopy": {{ section.settings.gate_copy | json }}
      },
      "regions": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'region' -%}
          {{ sep }}{ "label": {{ block.settings.label | json }}, "value": {{ block.settings.value | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "dayTypes": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'day_type' -%}
          {{ sep }}{ "label": {{ block.settings.label | json }}, "value": {{ block.settings.value | json }}, "image": {{ block.settings.image | image_url: width: 600 | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "terrain": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'terrain' -%}
          {{ sep }}{ "label": {{ block.settings.label | json }}, "value": {{ block.settings.value | json }}, "image": {{ block.settings.image | image_url: width: 400 | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "packageTiers": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'package_tier' -%}
          {{ sep }}{ "name": {{ block.settings.name | json }}, "blurb": {{ block.settings.blurb | json }}, "url": {{ block.settings.url | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "graphicCategories": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'graphic_category' -%}
          {{ sep }}{ "name": {{ block.settings.name | json }}, "collection": {{ block.settings.collection | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "featuredGraphics": [
        {%- assign sep = '' -%}
        {%- assign sd_fg_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'graphic_category' and block.settings.collection != blank -%}
            {%- assign sd_fg_col = collections[block.settings.collection] -%}
            {%- if sd_fg_col != blank -%}
              {%- for product in sd_fg_col.products -%}
                {%- if sd_fg_count < 5 and product.featured_image != blank -%}
                  {{ sep }}{ "image": {{ product.featured_image | image_url: width: 300 | json }}, "title": {{ product.title | json }} }
                  {%- assign sep = ',' -%}
                  {%- assign sd_fg_count = sd_fg_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if sd_fg_count == 0 and section.settings.graphics_collection != blank -%}
          {%- assign sd_fg_col = collections[section.settings.graphics_collection] -%}
          {%- for product in sd_fg_col.products -%}
            {%- if sd_fg_count < 5 and product.featured_image != blank -%}
              {{ sep }}{ "image": {{ product.featured_image | image_url: width: 300 | json }}, "title": {{ product.title | json }} }
              {%- assign sep = ',' -%}
              {%- assign sd_fg_count = sd_fg_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      ],
      "materials": [
        {%- assign sd_mat_sep = '' -%}
        {%- for mat in shop.metaobjects['material_library'].values -%}
          {%- if mat.active.value != false -%}
            {%- assign sd_mat_img = '' -%}
            {%- if mat.image.value != blank -%}
              {%- assign sd_mat_img = mat.image.value | image_url: width: 600 -%}
            {%- endif -%}
            {{ sd_mat_sep }}{
              "name": {{ mat.name.value | json }},
              "category": {{ mat.category.value | json }},
              "sub_category": {{ mat.sub_category.value | json }},
              "description": {{ mat.description.value | json }},
              "specs": {{ mat.specs.value | json }},
              "image": {{ sd_mat_img | json }},
              "personality_tags": {{ mat.personality_tags.value | json }},
              "damp_factor": {{ mat.damp_factor.value | default: 0 | plus: 0 }},
              "flex_factor": {{ mat.flex_factor.value | default: 0 | plus: 0 }},
              "speed_factor": {{ mat.speed_factor.value | default: 0 | plus: 0 }},
              "weight_factor": {{ mat.weight_factor.value | default: 0 | plus: 0 }}
            }
            {%- assign sd_mat_sep = ',' -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>

  {%- comment -%} Noscript fallback so the section is never blank pre-hydration {%- endcomment -%}
  <noscript>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subhead }}</p>
  </noscript>
</div>

{%- comment -%}
  Graphics explorer overlay — lives OUTSIDE #skier-dna-root so root.innerHTML
  replacements in skier-dna.js never destroy it.
    Source priority:
      1. graphic_category blocks — each block is one named collection tab.
      2. graphics_collection setting — single collection, tabs from product.type.
    Hidden until skier-dna.js sets overlay.hidden = false.
  {%- endcomment -%}

  {%- comment -%} Determine which source mode to use {%- endcomment -%}
  {%- assign sd_gv_block_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'graphic_category' and block.settings.collection != blank -%}
      {%- assign sd_gv_block_count = sd_gv_block_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if sd_gv_block_count > 0 or section.settings.graphics_collection != blank -%}

    {%- comment -%} Shared toolbar markup captured once {%- endcomment -%}
    <div id="sd-graphics-overlay" class="sd-gv-overlay" hidden aria-modal="true" role="dialog" aria-label="Explore graphics">

      <graphic-viewer
        class="graphic-viewer sd-gv-viewer"
        data-section-id="{{ section.id }}-gv"
        data-grid-panel-id="sd-gv-grid-{{ section.id }}"
      >

        <div class="graphic-viewer__toolbar">
          <button type="button" class="sd-gv-close" aria-label="Close graphics explorer" data-sd-gv-close>
            <svg viewBox="0 0 18 18" aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <line x1="3" y1="3" x2="15" y2="15"/><line x1="15" y1="3" x2="3" y2="15"/>
            </svg>
          </button>
          <button type="button" ref="modeBtns[]" class="graphic-viewer__mode-btn" data-mode="viewer"
            aria-pressed="true" aria-label="Viewer mode" on:click="graphic-viewer/handleModeToggle">
            <svg viewBox="0 0 18 18" aria-hidden="true"><rect x="1" y="1" width="7" height="16" rx="1"/><rect x="10" y="1" width="7" height="16" rx="1"/></svg>
          </button>
          <button type="button" ref="modeBtns[]" class="graphic-viewer__mode-btn" data-mode="grid"
            aria-pressed="false" aria-label="Grid mode" on:click="graphic-viewer/handleModeToggle">
            <svg viewBox="0 0 18 18" aria-hidden="true"><rect x="1" y="1" width="7" height="7" rx="1"/><rect x="10" y="1" width="7" height="7" rx="1"/><rect x="1" y="10" width="7" height="7" rx="1"/><rect x="10" y="10" width="7" height="7" rx="1"/></svg>
          </button>
        </div>

        <div class="graphic-viewer__viewer-panel" ref="viewerPanel">
          <aside class="graphic-viewer__sidebar">

            {%- if sd_gv_block_count > 0 -%}
              {%- comment -%}
                Multi-collection mode: one graphic_category block = one filter tab.
                data-tier = collection handle (stable, unique per block).
              {%- endcomment -%}
              <div class="graphic-viewer__filter-row" role="group" aria-label="Category filter">
                <button type="button" ref="tierBtns[]" class="graphic-viewer__tier-btn"
                  data-tier="all" aria-pressed="true" on:click="graphic-viewer/handleTierFilter">All</button>
                {%- for block in section.blocks -%}
                  {%- if block.type == 'graphic_category' and block.settings.collection != blank -%}
                    {%- assign sd_gv_col = collections[block.settings.collection] -%}
                    {%- if sd_gv_col != blank -%}
                      <button type="button" ref="tierBtns[]" class="graphic-viewer__tier-btn"
                        data-tier="{{ block.settings.collection | handleize }}"
                        aria-pressed="false"
                        on:click="graphic-viewer/handleTierFilter">
                        {{- block.settings.name | default: sd_gv_col.title -}}
                      </button>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <div class="graphic-viewer__thumb-list" role="list" aria-label="Graphics">
                {%- assign sd_gv_thumb_idx = 0 -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'graphic_category' and block.settings.collection != blank -%}
                    {%- assign sd_gv_col = collections[block.settings.collection] -%}
                    {%- if sd_gv_col != blank -%}
                      {%- for product in sd_gv_col.products -%}
                        <div ref="thumbs[]" class="graphic-viewer__thumb" role="button" tabindex="0"
                          data-handle="{{ product.handle }}"
                          data-tier="{{ block.settings.collection | handleize }}"
                          data-image="{{ product.featured_image | image_url: width: 1200 }}"
                          data-title="{{ product.title | escape }}"
                          data-collection="{{ block.settings.name | default: sd_gv_col.title | escape }}"
                          data-price="{{ product.price }}"
                          data-url="{{ product.url }}"
                          aria-label="{{ product.title | escape }}"
                          aria-pressed="{% if sd_gv_thumb_idx == 0 %}true{% else %}false{% endif %}"
                          on:click="graphic-viewer/handleThumbClick"
                          on:keydown="graphic-viewer/handleThumbKeydown"
                        >
                          {%- if product.featured_image -%}
                      <img src="{{ product.featured_image | image_url: width: 400 }}"
                        alt="{{ product.title | escape }}" loading="lazy" width="200" height="200"
                        class="graphic-viewer__thumb-img">
                    {%- endif -%}
                          {%- assign sd_gv_thumb_idx = sd_gv_thumb_idx | plus: 1 -%}
                        </div>
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>

            {%- else -%}
              {%- comment -%}
                Single-collection fallback: tabs from product.type.
              {%- endcomment -%}
              {%- assign sd_gv_col = collections[section.settings.graphics_collection] -%}
              {%- liquid
                assign gv_type_list = ''
                for product in sd_gv_col.products
                  assign type_key = product.type | handleize
                  if type_key != blank
                    assign type_seen = false
                    assign gv_types_so_far = gv_type_list | split: '|||'
                    for seen_entry in gv_types_so_far
                      assign seen_parts = seen_entry | split: '::'
                      if seen_parts[0] == type_key
                        assign type_seen = true
                      endif
                    endfor
                    unless type_seen
                      unless gv_type_list == ''
                        assign gv_type_list = gv_type_list | append: '|||'
                      endunless
                      assign gv_type_list = gv_type_list | append: type_key | append: '::' | append: product.type
                    endunless
                  endif
                endfor
                assign gv_unique_types = gv_type_list | split: '|||'
              -%}
              {%- if gv_unique_types.size > 0 -%}
                <div class="graphic-viewer__filter-row" role="group" aria-label="Category filter">
                  <button type="button" ref="tierBtns[]" class="graphic-viewer__tier-btn"
                    data-tier="all" aria-pressed="true" on:click="graphic-viewer/handleTierFilter">All</button>
                  {%- for type_entry in gv_unique_types -%}
                    {%- assign type_parts = type_entry | split: '::' -%}
                    <button type="button" ref="tierBtns[]" class="graphic-viewer__tier-btn"
                      data-tier="{{ type_parts[0] }}" aria-pressed="false"
                      on:click="graphic-viewer/handleTierFilter">{{ type_parts[1] }}</button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
              <div class="graphic-viewer__thumb-list" role="list" aria-label="Graphics">
                {%- for product in sd_gv_col.products -%}
                  <div ref="thumbs[]" class="graphic-viewer__thumb" role="button" tabindex="0"
                    data-handle="{{ product.handle }}"
                    data-tier="{{ product.type | handleize }}"
                    data-image="{{ product.featured_image | image_url: width: 1200 }}"
                    data-title="{{ product.title | escape }}"
                    data-collection="{{ product.type | escape }}"
                    data-price="{{ product.price }}"
                    data-url="{{ product.url }}"
                    aria-label="{{ product.title | escape }}"
                    aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
                    on:click="graphic-viewer/handleThumbClick"
                    on:keydown="graphic-viewer/handleThumbKeydown"
                  >
                    {%- if product.featured_image -%}
                      <img src="{{ product.featured_image | image_url: width: 400 }}"
                        alt="{{ product.title | escape }}" loading="lazy" width="200" height="200"
                        class="graphic-viewer__thumb-img">
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}

          </aside>

          <div class="graphic-viewer__stage-area">
            <div class="graphic-viewer__metadata" aria-live="polite" aria-atomic="true">
              <span class="graphic-viewer__metadata-series" ref="metaSeries"></span>
              <span class="graphic-viewer__metadata-name" ref="metaName"></span>
            </div>
            <div class="graphic-viewer__stage" ref="stage" aria-hidden="true">
              <div class="graphic-viewer__stage-layer" ref="stageLayers[]" data-layer="a"></div>
              <div class="graphic-viewer__stage-layer" ref="stageLayers[]" data-layer="b"></div>
            </div>
            <div class="graphic-viewer__info-strip">
              <div class="graphic-viewer__msrp">
                <span class="graphic-viewer__msrp-label">MSRP Starting At</span>
                <span class="graphic-viewer__msrp-value" ref="msrpValue"></span>
              </div>
              <div class="graphic-viewer__actions">
                <a ref="ctaPrimary" class="graphic-viewer__cta graphic-viewer__cta--primary" href="#">Customize This Pair</a>
                <a ref="ctaSecondary" class="graphic-viewer__cta graphic-viewer__cta--secondary" href="#">Technical Specs</a>
              </div>
            </div>
          </div>
        </div>

      </graphic-viewer>

      <div id="sd-gv-grid-{{ section.id }}" hidden></div>

    </div>

    {{ 'graphic-viewer.css' | asset_url | stylesheet_tag }}
    <script type="module">import '{{ 'graphic-viewer.js' | asset_url }}';</script>

{%- endif -%}

{{ 'skier-dna.css' | asset_url | stylesheet_tag }}
<script src="{{ 'skier-dna.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Skier DNA",
  "tag": "section",
  "class": "skier-dna-section",
  "settings": [
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "heading", "label": "Headline", "default": "Let's find your ski." },
    { "type": "textarea", "id": "subhead", "label": "Subhead", "default": "Answer a few questions and watch the ski we'd build for you come to life." },
    { "type": "text", "id": "name_prompt", "label": "Name prompt", "default": "First, what should we call you?" },
    { "type": "textarea", "id": "email_save_copy", "label": "Email-save copy", "default": "We'll email you your design so you don't lose it. No spam." },
    { "type": "text", "id": "micro_cta_label", "label": "Header micro-CTA (Act 3+)", "default": "Prefer to talk it through? Book a 20-min call." },
    { "type": "textarea", "id": "gate_copy", "label": "Act 4 gate copy", "default": "Ready for some personal questions? Optional, but they help us nail the spec." },

    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Typography & shape" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
    { "type": "font_picker", "id": "body_font", "label": "Body font", "default": "assistant_n4" },
    { "type": "range", "id": "corner_radius", "label": "Corner radius", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 8 },

    { "type": "header", "content": "Behavior" },
    { "type": "checkbox", "id": "show_package_tiers", "label": "Show recommended package tag in Act 5", "default": true },
    { "type": "checkbox", "id": "true_scale_anchor", "label": "Show true-scale body silhouette (Act 4)", "default": true },
    { "type": "range", "id": "header_offset", "label": "Theme header height (reserve so acts sit below sticky nav)", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },

    { "type": "header", "content": "Integrations" },
    { "type": "url", "id": "calendly_url", "label": "Calendly event URL" },
    { "type": "text", "id": "klaviyo_list_id", "label": "Klaviyo list ID" },
    { "type": "collection", "id": "graphics_collection", "label": "Topsheet graphics collection" },
    { "type": "text", "id": "personalities_api_url", "label": "Personalities AI endpoint URL", "info": "Cloudflare Worker URL for AI-generated personality names and descriptions. Leave blank to use static copy." }
  ],
  "blocks": [
    {
      "type": "region",
      "name": "Region",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Western NA" },
        { "type": "text", "id": "value", "label": "Value (stable key)", "default": "western_na" }
      ]
    },
    {
      "type": "day_type",
      "name": "Day type card",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Powder Days" },
        { "type": "text", "id": "value", "label": "Value (stable key)", "default": "powder" },
        { "type": "image_picker", "id": "image", "label": "Card image (placeholder ok)" }
      ]
    },
    {
      "type": "terrain",
      "name": "Terrain card",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Groomed" },
        { "type": "text", "id": "value", "label": "Value (stable key)", "default": "groomed" },
        { "type": "image_picker", "id": "image", "label": "Card image (placeholder ok)" }
      ]
    },
    {
      "type": "package_tier",
      "name": "Package tier",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Silver" },
        { "type": "textarea", "id": "blurb", "label": "Blurb" },
        { "type": "url", "id": "url", "label": "Detail page" }
      ]
    },
    {
      "type": "graphic_category",
      "name": "Graphic category",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "House Graphics" },
        { "type": "collection", "id": "collection", "label": "Source collection" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Skier DNA",
      "category": "Wagner",
      "blocks": [
        { "type": "region", "settings": { "label": "Western NA", "value": "western_na" } },
        { "type": "region", "settings": { "label": "Eastern NA", "value": "eastern_na" } },
        { "type": "region", "settings": { "label": "Europe", "value": "europe" } },
        { "type": "day_type", "settings": { "label": "Everyday", "value": "everyday" } },
        { "type": "day_type", "settings": { "label": "Powder Days", "value": "powder" } },
        { "type": "day_type", "settings": { "label": "Hard / Firm On-Piste", "value": "hard_firm" } },
        { "type": "day_type", "settings": { "label": "Ski Touring", "value": "touring" } },
        { "type": "terrain", "settings": { "label": "Groomed", "value": "groomed" } },
        { "type": "terrain", "settings": { "label": "Moguls", "value": "moguls" } },
        { "type": "terrain", "settings": { "label": "Resort Powder Bowls", "value": "bowls" } },
        { "type": "terrain", "settings": { "label": "Tree Runs", "value": "trees" } },
        { "type": "package_tier", "settings": { "name": "Essential" } },
        { "type": "package_tier", "settings": { "name": "Silver" } },
        { "type": "package_tier", "settings": { "name": "Ultra" } }
      ]
    }
  ]
}
{% endschema %}
