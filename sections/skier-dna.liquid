{%- comment -%}
  ============================================================================
  Skier DNA — Online Store 2.0 section scaffold
  ============================================================================
  This is a THEME SECTION version of the Skier DNA mount point. It is the
  fastest way to prototype the schema (settings + blocks) in a dev theme.

  PROMOTION TO A THEME APP EXTENSION APP BLOCK (do this once the app backend
  exists — it is what the experience actually ships as, because it needs
  server-side persistence + Klaviyo + Calendly + pre-generated copy):
    1. Move this file to  extensions/skier-dna/blocks/skier-dna.liquid
    2. Keep the {% schema %} settings + blocks EXACTLY as-is — they transfer 1:1.
    3. Replace `section.settings`/`section.blocks` with `block.settings`/
       `block.blocks`, and the `{% schema %}` "name"/"presets" with app-block
       equivalents (target: "section").
    4. Serve assets/skier-dna.js from the extension's assets/ folder.
  The five acts themselves are NEVER Liquid blocks — they are client app state
  inside #skier-dna-root. The blocks below are only the merchant-editable
  CONTENT COLLECTIONS, so Roland can re-image/re-order cards in the editor.
  ============================================================================
{%- endcomment -%}

<skier-dna-island
  id="skier-dna-root"
  class="color-{{ section.settings.color_scheme }}"
  data-skier-dna
  data-calendly-url="{{ section.settings.calendly_url | escape }}"
  data-klaviyo-list="{{ section.settings.klaviyo_list_id | escape }}"
  data-personalities-url="{{ section.settings.personalities_api_url | escape }}"
  data-show-packages="{{ section.settings.show_package_tiers }}"
  data-true-scale="{{ section.settings.true_scale_anchor }}"
  data-btn-continue="{{ section.settings.button_style_continue }}"
  data-btn-back="{{ section.settings.button_style_back }}"
  data-btn-cta="{{ section.settings.button_style_cta }}"
  {%- if section.settings.graphics_collection != blank %}
  data-graphics-collection="{{ section.settings.graphics_collection }}"
  {%- endif %}
  style="--sd-radius: {{ section.settings.corner_radius }}px;"
>

  {%- comment -%} Roland-editable copy + content, handed to the island as JSON {%- endcomment -%}
  <script type="application/json" data-skier-dna-config>
    {
      "copy": {
        "heading": {{ section.settings.heading | json }},
        "subhead": {{ section.settings.subhead | json }},
        "namePrompt": {{ section.settings.name_prompt | json }},
        "emailSaveCopy": {{ section.settings.email_save_copy | json }},
        "microCtaLabel": {{ section.settings.micro_cta_label | json }},
        "gateCopy": {{ section.settings.gate_copy | json }},
        "pageIntro": {{ page.content | default: '' | json }}
      },
      "regions": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'region' -%}
          {{ sep }}{ "label": {{ block.settings.label | json }}, "value": {{ block.settings.value | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "dayTypes": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'day_type' -%}
          {{ sep }}{ "label": {{ block.settings.label | json }}, "value": {{ block.settings.value | json }}, "image": {{ block.settings.image | image_url: width: 600 | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "terrain": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'terrain' -%}
          {{ sep }}{ "label": {{ block.settings.label | json }}, "value": {{ block.settings.value | json }}, "image": {{ block.settings.image | image_url: width: 400 | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "packageTiers": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'package_tier' -%}
          {{ sep }}{ "name": {{ block.settings.name | json }}, "blurb": {{ block.settings.blurb | json }}, "url": {{ block.settings.url | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "graphicCategories": [
        {%- assign sep = '' -%}
        {%- for block in section.blocks -%}{%- if block.type == 'graphic_category' -%}
          {{ sep }}{ "name": {{ block.settings.name | json }}, "collection": {{ block.settings.collection | json }} }
          {%- assign sep = ',' -%}
        {%- endif -%}{%- endfor -%}
      ],
      "featuredGraphics": [
        {%- assign sep = '' -%}
        {%- assign sd_fg_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'graphic_category' and block.settings.collection != blank -%}
            {%- assign sd_fg_col = collections[block.settings.collection] -%}
            {%- if sd_fg_col != blank -%}
              {%- for product in sd_fg_col.products -%}
                {%- if sd_fg_count < 5 and product.featured_image != blank -%}
                  {{ sep }}{ "image": {{ product.featured_image | image_url: width: 300 | json }}, "title": {{ product.title | json }} }
                  {%- assign sep = ',' -%}
                  {%- assign sd_fg_count = sd_fg_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if sd_fg_count == 0 and section.settings.graphics_collection != blank -%}
          {%- assign sd_fg_col = collections[section.settings.graphics_collection] -%}
          {%- for product in sd_fg_col.products -%}
            {%- if sd_fg_count < 5 and product.featured_image != blank -%}
              {{ sep }}{ "image": {{ product.featured_image | image_url: width: 300 | json }}, "title": {{ product.title | json }} }
              {%- assign sep = ',' -%}
              {%- assign sd_fg_count = sd_fg_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      ],
      "materials": [
        {%- assign sd_mat_sep = '' -%}
        {%- for mat in shop.metaobjects['material_library'].values -%}
          {%- if mat.active.value != false -%}
            {%- assign sd_mat_img = '' -%}
            {%- if mat.image.value != blank -%}
              {%- assign sd_mat_img = mat.image.value | image_url: width: 600 -%}
            {%- endif -%}
            {{ sd_mat_sep }}{
              "name": {{ mat.name.value | json }},
              "category": {{ mat.category.value | json }},
              "sub_category": {{ mat.sub_category.value | json }},
              "description": {{ mat.description.value | json }},
              "specs": {{ mat.specs.value | json }},
              "image": {{ sd_mat_img | json }},
              "personality_tags": {{ mat.personality_tags.value | json }},
              "damp_factor": {{ mat.damp_factor.value | default: 0 | plus: 0 }},
              "flex_factor": {{ mat.flex_factor.value | default: 0 | plus: 0 }},
              "speed_factor": {{ mat.speed_factor.value | default: 0 | plus: 0 }},
              "weight_factor": {{ mat.weight_factor.value | default: 0 | plus: 0 }}
            }
            {%- assign sd_mat_sep = ',' -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>

  {%- comment -%} Noscript fallback so the section is never blank pre-hydration {%- endcomment -%}
  <noscript>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subhead }}</p>
  </noscript>
</skier-dna-island>

{% render 'skier-dna-gv-overlay', section: section %}

{% render 'skier-dna-book-dialog', section: section %}

{{ 'skier-dna.css' | asset_url | stylesheet_tag }}
<script type="module">import '@theme/skier-dna';</script>

{% schema %}
{
  "name": "Skier DNA",
  "tag": "section",
  "class": "skier-dna-section",
  "settings": [
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "heading", "label": "Headline", "default": "Let's find your ski." },
    { "type": "textarea", "id": "subhead", "label": "Subhead", "default": "Answer a few questions and watch the ski we'd build for you come to life." },
    { "type": "text", "id": "name_prompt", "label": "Name prompt", "default": "First, what should we call you?" },
    { "type": "textarea", "id": "email_save_copy", "label": "Email-save copy", "default": "We'll email you your design so you don't lose it. No spam." },
    { "type": "text", "id": "micro_cta_label", "label": "Header micro-CTA (Act 3+)", "default": "Prefer to talk it through? Book a 20-min call." },
    { "type": "textarea", "id": "gate_copy", "label": "Act 4 gate copy", "default": "Ready for some personal questions? Optional, but they help us nail the spec." },

    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Button styles" },
    {
      "type": "select", "id": "button_style_continue", "label": "Continue \/ CTA buttons",
      "info": "Applies to Continue, See My Design, Book Call, and save actions",
      "options": [
        { "value": "theme_primary",   "label": "Theme primary button" },
        { "value": "theme_secondary", "label": "Theme secondary button" },
        { "value": "text",            "label": "Text link" }
      ],
      "default": "theme_primary"
    },
    {
      "type": "select", "id": "button_style_back", "label": "Back \/ navigation buttons",
      "options": [
        { "value": "theme_secondary", "label": "Theme secondary button" },
        { "value": "theme_primary",   "label": "Theme primary button" },
        { "value": "text",            "label": "Text link" }
      ],
      "default": "theme_secondary"
    },
    {
      "type": "select", "id": "button_style_cta", "label": "Secondary CTA buttons",
      "info": "Applies to Email Me This Design and similar secondary calls-to-action",
      "options": [
        { "value": "theme_secondary", "label": "Theme secondary button" },
        { "value": "theme_primary",   "label": "Theme primary button" },
        { "value": "text",            "label": "Text link" }
      ],
      "default": "theme_secondary"
    },
    { "type": "header", "content": "Shape" },
    { "type": "range", "id": "corner_radius", "label": "Corner radius", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 8 },

    { "type": "header", "content": "Behavior" },
    { "type": "checkbox", "id": "show_package_tiers", "label": "Show recommended package tag in Act 5", "default": true },
    { "type": "checkbox", "id": "true_scale_anchor", "label": "Show true-scale body silhouette (Act 4)", "default": true },

    { "type": "header", "content": "Integrations" },
    { "type": "url", "id": "calendly_url", "label": "Calendly event URL" },
    { "type": "text", "id": "klaviyo_list_id", "label": "Klaviyo list ID" },
    { "type": "collection", "id": "graphics_collection", "label": "Topsheet graphics collection" },
    { "type": "text", "id": "personalities_api_url", "label": "Personalities AI endpoint URL", "info": "Cloudflare Worker URL for AI-generated personality names and descriptions. Leave blank to use static copy." }
  ],
  "blocks": [
    {
      "type": "region",
      "name": "Region",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Western NA" },
        { "type": "text", "id": "value", "label": "Value (stable key)", "default": "western_na" }
      ]
    },
    {
      "type": "day_type",
      "name": "Day type card",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Powder Days" },
        { "type": "text", "id": "value", "label": "Value (stable key)", "default": "powder" },
        { "type": "image_picker", "id": "image", "label": "Card image (placeholder ok)" }
      ]
    },
    {
      "type": "terrain",
      "name": "Terrain card",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Groomed" },
        { "type": "text", "id": "value", "label": "Value (stable key)", "default": "groomed" },
        { "type": "image_picker", "id": "image", "label": "Card image (placeholder ok)" }
      ]
    },
    {
      "type": "package_tier",
      "name": "Package tier",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Silver" },
        { "type": "textarea", "id": "blurb", "label": "Blurb" },
        { "type": "url", "id": "url", "label": "Detail page" }
      ]
    },
    {
      "type": "graphic_category",
      "name": "Graphic category",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "House Graphics" },
        { "type": "collection", "id": "collection", "label": "Source collection" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Skier DNA",
      "category": "Wagner",
      "blocks": [
        { "type": "region", "settings": { "label": "Western NA", "value": "western_na" } },
        { "type": "region", "settings": { "label": "Eastern NA", "value": "eastern_na" } },
        { "type": "region", "settings": { "label": "Europe", "value": "europe" } },
        { "type": "day_type", "settings": { "label": "Everyday", "value": "everyday" } },
        { "type": "day_type", "settings": { "label": "Powder Days", "value": "powder" } },
        { "type": "day_type", "settings": { "label": "Hard / Firm On-Piste", "value": "hard_firm" } },
        { "type": "day_type", "settings": { "label": "Ski Touring", "value": "touring" } },
        { "type": "terrain", "settings": { "label": "Groomed", "value": "groomed" } },
        { "type": "terrain", "settings": { "label": "Moguls", "value": "moguls" } },
        { "type": "terrain", "settings": { "label": "Resort Powder Bowls", "value": "bowls" } },
        { "type": "terrain", "settings": { "label": "Tree Runs", "value": "trees" } },
        { "type": "package_tier", "settings": { "name": "Essential" } },
        { "type": "package_tier", "settings": { "name": "Silver" } },
        { "type": "package_tier", "settings": { "name": "Ultra" } }
      ]
    }
  ]
}
{% endschema %}
